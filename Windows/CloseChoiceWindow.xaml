<Window x:Class="TDM.Windows.CloseChoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="关闭 TDM"
        Width="420" Height="Auto"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">
    <Border CornerRadius="14"
            Background="{DynamicResource BackgroundBottomBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
            Padding="24,20,24,18"
            MouseLeftButtonDown="OnDragMove">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <Border Width="38" Height="38" CornerRadius="10"
                        Background="{DynamicResource PrimaryBrush}">
                    <Path Width="20" Height="20" Stretch="Uniform" Stroke="White" StrokeThickness="1.8" Fill="Transparent"
                          Data="M12,2 a10,10 0 1 0 0,20 a10,10 0 1 0 0,-20 M12,7 v6 M12,16 v0.01"/>
                </Border>
                <TextBlock Text="关闭 TDM" FontSize="17" FontWeight="Bold"
                           Foreground="{DynamicResource TextBrush}" Margin="12,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="22" Margin="0,0,0,18"
                       Foreground="{DynamicResource TextSecondaryBrush}">
                <Run Text="您希望接下来怎么做？您可以"/>
                <Run Text="最小化到托盘" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                <Run Text="继续在后台下载，或"/>
                <Run Text="直接退出" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                <Run Text="结束所有任务。"/>
            </TextBlock>

            <CheckBox x:Name="RememberCheck" Content="记住我的选择，以后不再询问（可在设置中更改）"
                      Style="{DynamicResource ModernCheckBox}" Margin="0,0,0,16"
                      IsChecked="True"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Content="取消" Style="{DynamicResource FlatButton}"
                        Click="OnCancelClick" Margin="0,0,8,0" MinWidth="90"/>
                <Button x:Name="TrayButton" Content="最小化到托盘" Style="{DynamicResource SecondaryButton}"
                        Click="OnTrayClick" Margin="0,0,8,0" MinWidth="120"/>
                <Button x:Name="ExitButton" Content="直接退出" Style="{DynamicResource PrimaryButton}"
                        Click="OnExitClick" MinWidth="120"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
