<Window x:Class="TDM.Windows.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TDM 实时日志（开发者模式）"
        Width="900" Height="560"
        MinWidth="600" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBottomBrush}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 头部工具栏 -->
        <Border Grid.Row="0" Padding="14,10"
                Background="{StaticResource BackgroundTopBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="实时日志" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"/>
                    <TextBlock x:Name="FilePathLabel" FontSize="11"
                               Foreground="{StaticResource SubTextBrush}" Margin="0,2,0,0"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <CheckBox x:Name="AutoScrollCheck" Content="自动滚动到底部"
                              IsChecked="True" VerticalAlignment="Center" Margin="0,0,12,0"
                              Style="{StaticResource ModernCheckBox}"/>
                    <CheckBox x:Name="FollowTailCheck" Content="实时跟踪新日志"
                              IsChecked="True" VerticalAlignment="Center" Margin="0,0,12,0"
                              Style="{StaticResource ModernCheckBox}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 过滤 -->
        <Border Grid.Row="1" Padding="14,8"
                Background="{StaticResource BackgroundBottomBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="过滤：" VerticalAlignment="Center"
                           Foreground="{StaticResource SubTextBrush}" Margin="0,0,8,0"/>
                <ToggleButton x:Name="FilterInfo" Tag="INFO" Margin="0,0,6,0"
                              IsChecked="True" Style="{StaticResource LogFilterToggle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Width="10" Height="10" Stretch="Uniform" Fill="White" Data="{StaticResource IconInfoSmall}" Margin="0,0,4,0"/>
                        <TextBlock Text="INFO" VerticalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton x:Name="FilterWarn" Tag="WARN" Margin="0,0,6,0"
                              IsChecked="True" Style="{StaticResource LogFilterToggle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Width="10" Height="10" Stretch="Uniform" Fill="White" Data="{StaticResource IconWarn}" Margin="0,0,4,0"/>
                        <TextBlock Text="WARN" VerticalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton x:Name="FilterError" Tag="ERROR" Margin="0,0,6,0"
                              IsChecked="True" Style="{StaticResource LogFilterToggle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Width="10" Height="10" Stretch="Uniform" Fill="White" Data="{StaticResource IconError}" Margin="0,0,4,0"/>
                        <TextBlock Text="ERROR" VerticalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton x:Name="FilterDebug" Tag="DEBUG" Margin="0,0,12,0"
                              IsChecked="True" Style="{StaticResource LogFilterToggle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Width="10" Height="10" Stretch="Uniform" Fill="White" Data="{StaticResource IconBug}" Margin="0,0,4,0"/>
                        <TextBlock Text="DEBUG" VerticalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
                <TextBox x:Name="SearchBox" Width="200" Style="{StaticResource ModernTextBox}"
                         ToolTip="搜索关键字（高亮显示）"/>
                <Button x:Name="ClearLogButton" Margin="6,0,0,0"
                        Style="{StaticResource FlatButton}" Padding="12,4" Click="OnClearLog">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Width="12" Height="12" Stretch="Uniform" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Data="{StaticResource IconTrash}" Margin="0,0,4,0"/>
                        <TextBlock Text="清屏" VerticalAlignment="Center" FontSize="12"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- 日志内容 -->
        <RichTextBox Grid.Row="2" x:Name="LogView" IsReadOnly="True"
                     FontFamily="{StaticResource MonoFontFamily}" FontSize="12"
                     Background="#1e1e2e" Foreground="#d4d4d4"
                     BorderThickness="0" Padding="10,8"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto">
            <FlowDocument PageWidth="2000" LineHeight="1">
                <Paragraph x:Name="LogParagraph"/>
            </FlowDocument>
        </RichTextBox>

        <!-- 底部状态栏 -->
        <Border Grid.Row="3" Padding="14,8" Style="{StaticResource StatusBarStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock x:Name="LineCountLabel" Text="共 0 行" Style="{StaticResource StatusLabel}"
                               Foreground="{StaticResource SubTextBrush}"/>
                    <TextBlock x:Name="LastUpdateLabel" Text="" Style="{StaticResource StatusLabel}"
                               Foreground="{StaticResource SubTextBrush}" Margin="16,0,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="OpenFolderButton"
                            Style="{StaticResource FlatButton}" Padding="12,4" Margin="0,0,6,0"
                            Click="OnOpenFolder">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Width="12" Height="12" Stretch="Uniform" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Data="{StaticResource IconFolder}" Margin="0,0,4,0"/>
                            <TextBlock Text="打开日志目录" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="CopyButton"
                            Style="{StaticResource PrimaryButton}" Padding="12,4" Margin="0,0,6,0"
                            Click="OnCopyAll">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Width="12" Height="12" Stretch="Uniform" Fill="White" Data="{StaticResource IconCopy}" Margin="0,0,4,0"/>
                            <TextBlock Text="复制全部" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="CloseButton"
                            Style="{StaticResource FlatButton}" Padding="12,4"
                            Click="OnCloseClick">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Width="12" Height="12" Stretch="Uniform" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Fill="Transparent" Data="{StaticResource IconClose}" Margin="0,0,4,0"/>
                            <TextBlock Text="关闭" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
