<Window x:Class="TDM.Windows.AlreadyRunningWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TDM 已在运行"
        Width="420" Height="Auto"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        Topmost="True">
    <Border CornerRadius="14"
            Background="{DynamicResource BackgroundBottomBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
            Padding="24,20,24,18"
            MouseLeftButtonDown="OnDragMove">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <Border Width="38" Height="38" CornerRadius="10"
                        Background="{DynamicResource PrimaryBrush}">
                    <Path Width="20" Height="20" Stretch="Uniform" Stroke="White" StrokeThickness="1.8" Fill="Transparent"
                          Data="{StaticResource IconInfo}"/>
                </Border>
                <TextBlock Text="TDM 已在运行" FontSize="17" FontWeight="Bold"
                           Foreground="{DynamicResource TextBrush}" Margin="12,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="22" Margin="0,0,0,18"
                       Foreground="{DynamicResource TextSecondaryBrush}">
                <Run Text="TDM 已经在后台运行。"/>
                <Run Text="打开主界面" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                <Run Text="可以继续管理下载任务，或点击取消保持当前状态。"/>
            </TextBlock>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Style="{DynamicResource FlatButton}"
                        Click="OnCancelClick" Margin="0,0,8,0" MinWidth="90" Padding="12,6">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Width="14" Height="14" Stretch="Uniform" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Fill="Transparent" Data="{StaticResource IconCancel}" Margin="0,0,5,0"/>
                        <TextBlock Text="取消" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="OpenButton" Style="{DynamicResource PrimaryButton}"
                        Click="OnOpenClick" MinWidth="140" Padding="12,6">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Width="14" Height="14" Stretch="Uniform" Stroke="White" StrokeThickness="1.8" Fill="Transparent" Data="{StaticResource IconOpen}" Margin="0,0,5,0"/>
                        <TextBlock Text="打开主界面" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
