<Window x:Class="TDM.Windows.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关于 TDM"
        Width="480" Height="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Style="{StaticResource MainWindowStyle}"
        Background="Transparent">
    <Border CornerRadius="14" Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="6">
        <Grid Margin="28,24,28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 头部品牌 -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,18">
                <Border Width="72" Height="72" CornerRadius="20"
                        Background="{StaticResource BrandGradientBrush}"
                        Effect="{StaticResource PrimaryGlow}"
                        HorizontalAlignment="Center" Margin="0,0,0,14">
                    <TextBlock Text="T" FontFamily="{StaticResource UIFontFamily}"
                               FontSize="38" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="TDSI Download Manager" Style="{StaticResource H1}"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="VersionText" Text="v1.0.0"
                           Style="{StaticResource BodySecondary}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- 内容 -->
            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="20">
                <StackPanel>
                    <TextBlock Text="现代化多线程下载管理器" Style="{StaticResource GroupTitle}" Margin="0,0,0,10"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource BodySecondary}" FontSize="12" LineHeight="22">
                        <Run Text="• 多线程分片下载，断点续传"/>
                        <LineBreak/>
                        <Run Text="• 智能资源嗅探"/>
                        <LineBreak/>
                        <Run Text="• 剪贴板自动识别"/>
                        <LineBreak/>
                        <Run Text="• 现代化界面，多主题切换"/>
                    </TextBlock>
                    <Border Height="1" Background="{StaticResource DividerBrush}" Margin="0,14,0,14"/>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="作者：" Style="{StaticResource SubText}" VerticalAlignment="Center"/>
                        <TextBlock Margin="6,0,0,0" VerticalAlignment="Center">
                            <Hyperlink x:Name="AuthorLink" Click="OnAuthorClick" Foreground="{StaticResource PrimaryBrush}"
                                       TextDecorations="None" FontWeight="SemiBold">B站@会飞的附魔下界合金剑</Hyperlink>
                        </TextBlock>
                    </DockPanel>
                    <DockPanel>
                        <TextBlock Text="项目：" Style="{StaticResource SubText}" VerticalAlignment="Center"/>
                        <TextBlock Margin="6,0,0,0" VerticalAlignment="Center">
                            <Hyperlink x:Name="GithubLink" Click="OnGithubClick" Foreground="{StaticResource PrimaryBrush}"
                                       TextDecorations="None" FontWeight="SemiBold">github.com/TDSI-g84nm7nfmi/TDM</Hyperlink>
                        </TextBlock>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- 底部 -->
            <DockPanel Grid.Row="2" Margin="0,18,0,0">
                <Border Background="{StaticResource BrandGradientBrush}" CornerRadius="10" Padding="14,10">
                    <StackPanel>
                        <TextBlock Text="你在找好玩的 Minecraft 服务器吗？" Foreground="White"
                                   FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Margin="0,4,0,0" FontSize="12">
                            <Run Text="点击这里 →" Foreground="#CCFFFFFF"/>
                            <Hyperlink x:Name="TdsiLink" Click="OnTdsiClick" Foreground="White"
                                       FontWeight="Bold" TextDecorations="None">TDSI 服务器</Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Button Style="{StaticResource PrimaryButton}" Content="关闭" Width="90" Height="38"
                        Click="OnCloseClick" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="12,12,0,0"/>
            </DockPanel>
        </Grid>
    </Border>
</Window>