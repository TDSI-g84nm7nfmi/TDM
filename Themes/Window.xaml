<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 主窗口样式 -->
    <Style x:Key="MainWindowStyle" TargetType="Window">
        <Setter Property="FontFamily" Value="{StaticResource UIFontFamily}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    </Style>

    <!-- 标题栏 -->
    <Style x:Key="TitleBar" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="#E6F0F8FB"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Height" Value="48"/>
        <Setter Property="Padding" Value="14,0,8,0"/>
    </Style>

    <!-- 状态栏 -->
    <Style x:Key="StatusBarStyle" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="#E6F0F8FB"/>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
        <Setter Property="MinHeight" Value="44"/>
        <Setter Property="Padding" Value="12,8"/>
    </Style>

    <!-- 侧边导航 -->
    <Style x:Key="Sidebar" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="#CCEDF4FB"/>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
        <Setter Property="Width" Value="168"/>
    </Style>

    <!-- TabControl 样式（备用） -->
    <Style x:Key="ModernTabControl" TargetType="TabControl">
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Background" Value="White"/>
    </Style>
</ResourceDictionary>
