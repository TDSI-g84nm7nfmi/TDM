<Window x:Class="TDM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TDM"
        xmlns:vm="clr-namespace:TDM.ViewModels"
        xmlns:views="clr-namespace:TDM.Views"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="TDM - TDSI Download Manager"
        Width="900" Height="600"
        MinWidth="720" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource MainWindowStyle}"
        Background="Transparent"
        AllowDrop="True"
        Drop="OnWindowDrop"
        DragEnter="OnWindowDragEnter">

    <Window.TaskbarItemInfo>
        <TaskbarItemInfo/>
    </Window.TaskbarItemInfo>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 标题栏 -->
            <RowDefinition Height="*"/>     <!-- 内容 -->
            <RowDefinition Height="Auto"/>  <!-- 状态栏 -->
        </Grid.RowDefinitions>

        <!-- 整体渐变背景（毛玻璃启用时半透明，未启用时不透明） -->
        <Border Grid.Row="0" Grid.RowSpan="3" x:Name="RootBackdrop">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#F0F5FC" Offset="0"/>
                    <GradientStop Color="#E8EEF7" Offset="0.5"/>
                    <GradientStop Color="#F5F8FC" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- 主题切换时的"水波纹"高光层（默认隐藏，主题切换时短暂扫过） -->
        <Rectangle Grid.Row="0" Grid.RowSpan="3" x:Name="ThemeSweep"
                   IsHitTestVisible="False" Opacity="0" Visibility="Collapsed">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1" x:Name="ThemeSweepBrush">
                    <GradientStop Color="#22FFFFFF" Offset="0"/>
                    <GradientStop Color="#44FFFFFF" Offset="0.5"/>
                    <GradientStop Color="#22FFFFFF" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Style="{StaticResource TitleBar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image x:Name="AppIconImage" Width="22" Height="22" Margin="0,0,10,0"/>
                    <TextBlock Text="TDM" FontFamily="{StaticResource UIFontFamily}" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="  ·  TDSI Download Manager" FontFamily="{StaticResource UIFontFamily}" FontSize="11"
                               Foreground="{StaticResource SubTextBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="MinimizeButton" Style="{StaticResource IconButton}" ToolTip="最小化到托盘"
                            Click="OnMinimizeClick">
                        <Path Data="M3,12 L17,12" Stroke="{StaticResource PrimaryBrush}" StrokeThickness="2"
                              Width="20" Height="20" Stretch="Uniform"/>
                    </Button>
                    <Button x:Name="AboutButton" Style="{StaticResource IconButton}" ToolTip="关于"
                            Click="OnAboutClick" Margin="4,0,0,0">
                        <Path Data="M12,2 A10,10 0 1 0 12,22 A10,10 0 1 0 12,2 M12,7 v0.01 M12,11 v6"
                              Stroke="{StaticResource PrimaryBrush}" StrokeThickness="1.6"
                              Width="20" Height="20" Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主内容 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>  <!-- 侧边导航 -->
                <ColumnDefinition Width="*"/>     <!-- 视图 -->
            </Grid.ColumnDefinitions>

            <!-- 侧边栏 -->
            <Border Grid.Column="0" Style="{StaticResource Sidebar}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="导航" Style="{StaticResource SubText}"
                               Margin="18,16,0,8" FontWeight="SemiBold"/>
                    <ListBox x:Name="NavList" Style="{StaticResource SidebarListBox}"
                             SelectionChanged="OnNavChanged" BorderThickness="0">
                        <ListBoxItem x:Name="NavWelcome" Tag="welcome">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z" 
                              Fill="{StaticResource PrimaryBrush}" Width="18" Height="18" Stretch="Uniform"/>
                                <TextBlock Text="欢迎" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem x:Name="NavDownload" Tag="download">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="M12,3 v12 M6,11 l6,6 6,-6 M5,21 h14"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                      StrokeThickness="1.6" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                <TextBlock Text="下载任务" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem x:Name="NavHistory" Tag="history">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="M12,8 v5 l3,2 M21,12 a9,9 0 1 1 -3,-6.7 M3,12 a9,9 0 0 0 9,9"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                      StrokeThickness="1.6" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                <TextBlock Text="历史记录" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem x:Name="NavSettings" Tag="settings">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="M12,15 a3,3 0 1 0 0,-6 a3,3 0 0 0 0,6 z M19.4,15 a1.65,1.65 0 0 0 0.33,1.82 l0.06,0.06 a2,2 0 1 1 -2.83,2.83 l-0.06,-0.06 a1.65,1.65 0 0 0 -1.82,-0.33 1.65,1.65 0 0 0 -1,1.51 V21 a2,2 0 1 1 -4,0 v-0.09 a1.65,1.65 0 0 0 -1,-1.51 1.65,1.65 0 0 0 -1.82,0.33 l-0.06,0.06 a2,2 0 1 1 -2.83,-2.83 l0.06,-0.06 a1.65,1.65 0 0 0 0.33,-1.82 1.65,1.65 0 0 0 -1.51,-1 H3 a2,2 0 1 1 0,-4 h0.09 a1.65,1.65 0 0 0 1.51,-1 1.65,1.65 0 0 0 -0.33,-1.82 l-0.06,-0.06 a2,2 0 1 1 2.83,-2.83 l0.06,0.06 a1.65,1.65 0 0 0 1.82,0.33 h0.01 a1.65,1.65 0 0 0 1,-1.51 V3 a2,2 0 1 1 4,0 v0.09 a1.65,1.65 0 0 0 1,1.51 1.65,1.65 0 0 0 1.82,-0.33 l0.06,-0.06 a2,2 0 1 1 2.83,2.83 l-0.06,0.06 a1.65,1.65 0 0 0 -0.33,1.82 v0.01 a1.65,1.65 0 0 0 1.51,1 H21 a2,2 0 1 1 0,4 h-0.09 a1.65,1.65 0 0 0 -1.51,1 z"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                      StrokeThickness="1.4" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                <TextBlock Text="设置" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- 视图区域 -->
            <ContentControl Grid.Column="1" x:Name="ViewHost" Margin="0"/>
        </Grid>

        <!-- 状态栏 -->
        <Border Grid.Row="2" Style="{StaticResource StatusBarStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusLabel" Grid.Column="0" Text="就绪" Style="{StaticResource StatusLabel}"
                           Foreground="{StaticResource SubTextBrush}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock x:Name="DownloadCountLabel" Text="0 个任务" Style="{StaticResource StatusLabel}"
                               Foreground="{StaticResource SubTextBrush}" Margin="0,0,16,0"/>
                    <TextBlock x:Name="VersionLabel" Text="v1.0.0" Style="{StaticResource StatusLabel}"
                               Foreground="{StaticResource SubTextBrush}" Cursor="Hand"
                               MouseLeftButtonUp="OnVersionLabelClick"
                               ToolTip="点击查看版本信息（连续点击 5 次进入开发者模式）"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
