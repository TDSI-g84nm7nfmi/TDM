<Window x:Class="TDM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TDM"
        xmlns:vm="clr-namespace:TDM.ViewModels"
        xmlns:views="clr-namespace:TDM.Views"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="TDM · TDSI Download Manager"
        Width="1100" Height="700"
        MinWidth="880" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource MainWindowStyle}"
        Background="Transparent"
        AllowDrop="True"
        Drop="OnWindowDrop"
        DragEnter="OnWindowDragEnter">

    <Window.TaskbarItemInfo>
        <TaskbarItemInfo/>
    </Window.TaskbarItemInfo>

    <Border CornerRadius="14" Background="{StaticResource BackgroundBottomBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>

            <!-- 动态光晕背景 -->
            <Rectangle Grid.Row="0" Grid.RowSpan="3" x:Name="GlowBg" IsHitTestVisible="False" Opacity="0.8">
                <Rectangle.Fill>
                    <VisualBrush Stretch="None" TileMode="None" AlignmentX="Left" AlignmentY="Top">
                        <VisualBrush.Visual>
                            <Grid Width="1100" Height="700">
                                <Ellipse Width="700" Height="700" Fill="{StaticResource GlowTopLeftBrush}"/>
                                <Ellipse Width="800" Height="800" Fill="{StaticResource GlowBottomRightBrush}"
                                         HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                            </Grid>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- 主题切换水波纹 -->
            <Rectangle Grid.Row="0" Grid.RowSpan="3" x:Name="ThemeSweep" IsHitTestVisible="False"
                       Opacity="0" Visibility="Collapsed">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1" x:Name="ThemeSweepBrush">
                        <GradientStop Color="#22FFFFFF" Offset="0"/>
                        <GradientStop Color="#44FFFFFF" Offset="0.5"/>
                        <GradientStop Color="#22FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- ===================== 标题栏 ===================== -->
            <Grid Grid.Row="0">
                <Border Background="Transparent">
                    <Grid Margin="20,0,12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 品牌区 -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="32" Height="32" CornerRadius="9"
                                    Background="{StaticResource BrandGradientBrush}"
                                    Effect="{StaticResource PrimaryGlow}">
                                <TextBlock Text="T" FontFamily="{StaticResource UIFontFamily}"
                                           FontSize="18" FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="TDM" FontFamily="{StaticResource UIFontFamily}"
                                           FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="TDSI Download Manager" FontFamily="{StaticResource UIFontFamily}"
                                           FontSize="10" Foreground="{StaticResource SubTextBrush}" Margin="0,-1,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- 搜索框（中央） -->
                        <Border Grid.Column="1" MaxWidth="380" Margin="40,0,40,0"
                                Background="{StaticResource SurfaceAltBrush}" CornerRadius="20"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                VerticalAlignment="Center" Padding="14,0,14,0" Height="32">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path Grid.Column="0" Width="14" Height="14" Stretch="Uniform"
                                      Fill="{StaticResource SubTextBrush}"
                                      Data="M11,3 a8,8 0 1 0 4,14 l5,5 2,-2 -5,-5 a8,8 0 0 0 -6,-12 z M11,5 a6,6 0 1 1 0,12 a6,6 0 0 1 0,-12 z"/>
                                <TextBox x:Name="QuickSearchBox" Grid.Column="1"
                                         BorderThickness="0" Background="Transparent" Margin="8,0,0,0"
                                         FontFamily="{StaticResource UIFontFamily}" FontSize="12"
                                         Foreground="{StaticResource TextBrush}"
                                         CaretBrush="{StaticResource PrimaryBrush}"
                                         VerticalContentAlignment="Center"
                                         KeyDown="OnQuickSearchKeyDown"
                                         Tag="搜索下载、文件、设置..."/>
                            </Grid>
                        </Border>

                        <!-- 工具按钮 -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="ThemeButton" Style="{StaticResource IconButton}" ToolTip="切换主题（循环：蓝/绿/紫/粉/深）"
                                    Click="OnThemeToggleClick" Margin="0,0,2,0">
                                <Path Width="18" Height="18" Stretch="Uniform"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.6" Fill="Transparent"
                                      Data="M12,3 a9,9 0 1 0 9,9 c0,-0.46 -0.04,-0.92 -0.1,-1.36 a5.39,5.39 0 0 1 -4.4,2.26 a5.5,5.5 0 0 1 -3.95,-1.65 a5.5,5.5 0 0 1 -1.65,-3.95 c0,-1.74 0.99,-3.31 2.5,-4.05 a9.05,9.05 0 0 0 -1.4,-0.25 z"/>
                            </Button>
                            <Button x:Name="AboutButton" Style="{StaticResource IconButton}" ToolTip="关于 TDM"
                                    Click="OnAboutClick" Margin="0,0,2,0">
                                <Path Width="18" Height="18" Stretch="Uniform"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.6" Fill="Transparent"
                                      Data="M12,2 A10,10 0 1 0 12,22 A10,10 0 1 0 12,2 M12,16 v0.01 M12,8 v5"/>
                            </Button>
                            <!-- 分隔线 -->
                            <Border Width="1" Height="18" Background="{StaticResource DividerBrush}" Margin="6,0"/>
                            <!-- 最小化 -->
                            <Button x:Name="MinimizeButton" Style="{StaticResource IconButton}" ToolTip="最小化到托盘"
                                    Click="OnMinimizeClick" Margin="0,0,2,0">
                                <Path Width="18" Height="2" Stretch="Uniform"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.6" Fill="Transparent"
                                      Data="M2,1 L18,1"/>
                            </Button>
                            <!-- 最大化/还原 -->
                            <Button x:Name="MaximizeButton" Style="{StaticResource IconButton}" ToolTip="最大化"
                                    Click="OnMaximizeClick" Margin="0,0,2,0">
                                <Path Width="18" Height="18" Stretch="Uniform"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.6" Fill="Transparent"
                                      Data="M4,4 H16 V16 H4 Z M4,4 L16,16 M16,4 L4,16"/>
                            </Button>
                            <!-- 关闭 -->
                            <Button x:Name="CloseButton" Style="{StaticResource IconButton}" ToolTip="关闭"
                                    Click="OnCloseClick">
                                <Path Width="18" Height="18" Stretch="Uniform"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.6" Fill="Transparent"
                                      Data="M6,6 L18,18 M18,6 L6,18"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
                <!-- 标题栏底部分隔线 -->
                <Border Height="1" VerticalAlignment="Bottom"
                        Background="{StaticResource DividerBrush}" IsHitTestVisible="False"/>
            </Grid>

            <!-- ===================== 主体 ===================== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{StaticResource SidebarWidth}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 侧边栏 -->
                <Border Grid.Column="0" Background="{StaticResource SidebarTopBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                    <DockPanel>
                        <!-- 快速添加 URL -->
                        <Border DockPanel.Dock="Top" Margin="16,20,16,4">
                            <Button x:Name="NewDownloadButton" Style="{StaticResource PrimaryButton}"
                                    Click="OnNewDownloadClick" Height="42" HorizontalContentAlignment="Left"
                                    Padding="14,0,12,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Path Width="16" Height="16" Stretch="Uniform" Fill="White"
                                          Data="M11,5 H13 V11 H19 V13 H13 V19 H11 V13 H5 V11 H11 z"/>
                                    <TextBlock Text="新建下载" Margin="10,0,0,0" FontWeight="SemiBold" FontSize="13"/>
                                </StackPanel>
                            </Button>
                        </Border>

                        <TextBlock DockPanel.Dock="Top" Text="导航" Style="{StaticResource SubText}"
                                   FontWeight="SemiBold" FontSize="11"
                                   Margin="20,18,0,8"
                                   Foreground="{StaticResource SubTextBrush}"/>

                        <!-- 底部用户区 -->
                        <Border DockPanel.Dock="Bottom" Margin="16,8,16,16" Padding="12"
                                Background="{StaticResource SurfaceBrush}" CornerRadius="12"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="32" Height="32" CornerRadius="16"
                                            Background="{StaticResource BrandGradientBrush}">
                                        <TextBlock Text="B" FontFamily="{StaticResource UIFontFamily}"
                                                   FontSize="14" FontWeight="Bold" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="会飞的附魔下界合金剑" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}"/>
                                        <TextBlock Text="TDSI 团队" FontSize="10"
                                                   Foreground="{StaticResource SubTextBrush}" Margin="0,1,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border Height="1" Background="{StaticResource DividerBrush}" Margin="0,10,0,8"/>
                                <Button x:Name="ExtensionStatusButton" Style="{StaticResource GhostButton}"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                        Click="OnExtensionStatusClick" Height="32" Padding="0,0,0,0" Margin="-6,0,-6,0">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse x:Name="ExtStatusDot" Width="8" Height="8" Fill="#1BC982"
                                                 VerticalAlignment="Center"/>
                                        <TextBlock x:Name="ExtStatusText" Text="扩展就绪" Margin="8,0,0,0"
                                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- 导航列表 -->
                        <ListBox x:Name="NavList" Style="{StaticResource SidebarListBox}"
                                 SelectionChanged="OnNavChanged" BorderThickness="0"
                                 Margin="0,0,0,8" Background="Transparent">
                            <ListBoxItem x:Name="NavWelcome" Tag="welcome">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Path Width="18" Height="18" Stretch="Uniform"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                          Data="M12,2 A10,10 0 1 0 12,22 A10,10 0 1 0 12,2 M12,6 v6 l4,2"/>
                                    <TextBlock Text="欢迎" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="14"/>
                                </StackPanel>
                            </ListBoxItem>
                            <ListBoxItem x:Name="NavDownload" Tag="download">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Path Width="18" Height="18" Stretch="Uniform"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                          Data="M12,3 v10 M7,9 l5,5 5,-5 M5,21 h14 M3,5 h4 M17,5 h4"/>
                                    <TextBlock Text="下载任务" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="14"/>
                                </StackPanel>
                            </ListBoxItem>
                            <ListBoxItem x:Name="NavHistory" Tag="history">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Path Width="18" Height="18" Stretch="Uniform"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                          Data="M12,8 v5 l3,2 M21,12 a9,9 0 1 1 -3,-6.7 M3,12 a9,9 0 0 0 9,9"/>
                                    <TextBlock Text="历史记录" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="14"/>
                                </StackPanel>
                            </ListBoxItem>
                            <ListBoxItem x:Name="NavSettings" Tag="settings">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Path Width="18" Height="18" Stretch="Uniform"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                          Data="M12,15 a3,3 0 1 0 0,-6 a3,3 0 0 0 0,6 z M19.4,15 a1.65,1.65 0 0 0 0.33,1.82 l0.06,0.06 a2,2 0 1 1 -2.83,2.83 l-0.06,-0.06 a1.65,1.65 0 0 0 -1.82,-0.33 1.65,1.65 0 0 0 -1,1.51 V21 a2,2 0 1 1 -4,0 v-0.09 a1.65,1.65 0 0 0 -1,-1.51 1.65,1.65 0 0 0 -1.82,0.33 l-0.06,0.06 a2,2 0 1 1 -2.83,-2.83 l0.06,-0.06 a1.65,1.65 0 0 0 0.33,-1.82 1.65,1.65 0 0 0 -1.51,-1 H3 a2,2 0 1 1 0,-4 h0.09 a1.65,1.65 0 0 0 1.51,-1 1.65,1.65 0 0 0 -0.33,-1.82 l-0.06,-0.06 a2,2 0 1 1 2.83,-2.83 l0.06,0.06 a1.65,1.65 0 0 0 1.82,0.33 h0.01 a1.65,1.65 0 0 0 1,-1.51 V3 a2,2 0 1 1 4,0 v0.09 a1.65,1.65 0 0 0 1,1.51 1.65,1.65 0 0 0 1.82,-0.33 l0.06,-0.06 a2,2 0 1 1 2.83,2.83 l-0.06,0.06 a1.65,1.65 0 0 0 -0.33,1.82 v0.01 a1.65,1.65 0 0 0 1.51,1 H21 a2,2 0 1 1 0,4 h-0.09 a1.65,1.65 0 0 0 -1.51,1 z"/>
                                    <TextBlock Text="设置" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="14"/>
                                </StackPanel>
                            </ListBoxItem>
                        </ListBox>
                    </DockPanel>
                </Border>

                <!-- 视图区域 -->
                <ContentControl Grid.Column="1" x:Name="ViewHost" Margin="0"/>
            </Grid>

            <!-- ===================== 状态栏 ===================== -->
            <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,14,14">
                <Grid Margin="20,0,20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot" Width="6" Height="6" Fill="{StaticResource SuccessBrush}"
                                 VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusLabel" Text="就绪" Margin="8,0,0,0"
                                   FontFamily="{StaticResource UIFontFamily}" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock x:Name="SpeedLabel" Grid.Column="1" Text="--"
                               FontFamily="{StaticResource MonoFontFamily}" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0"/>

                    <TextBlock x:Name="DownloadCountLabel" Grid.Column="2" Text="0 个任务"
                               FontFamily="{StaticResource UIFontFamily}" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0"/>

                    <TextBlock x:Name="VersionLabel" Grid.Column="3" Text="v1.0.0"
                               FontFamily="{StaticResource UIFontFamily}" FontSize="12"
                               Foreground="{StaticResource SubTextBrush}" Cursor="Hand"
                               MouseLeftButtonUp="OnVersionLabelClick" VerticalAlignment="Center"
                               ToolTip="点击查看版本信息（连续点击 5 次进入开发者模式）"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>