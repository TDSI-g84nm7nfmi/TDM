<Window x:Class="TDM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:notify="using:H.NotifyIcon"
        mc:Ignorable="d"
        Title="TDM · TDSI Download Manager">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="{ThemeResource SystemChromeLowColor}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Width="20" Height="20" Stretch="Uniform"
                   Source="ms-appx:///image/icon.png" Margin="12,0,8,0"/>
            <TextBlock Grid.Column="0" Text="TDM" VerticalAlignment="Center"
                       FontSize="13" FontWeight="SemiBold" Margin="40,0,0,0"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                <Button x:Name="ThemeButton" Width="34" Height="34" ToolTipService.ToolTip="切换主题"
                        Click="OnThemeToggleClick" Background="Transparent">
                    <TextBlock Text="&#xE790;" FontFamily="{ThemeResource SymbolThemeFontFamily}"/>
                </Button>
                <Button x:Name="MinimizeButton" Width="46" Height="34" ToolTipService.ToolTip="最小化"
                        Click="OnMinimizeClick" Background="Transparent">
                    <TextBlock Text="&#xE921;" FontFamily="{ThemeResource SymbolThemeFontFamily}"/>
                </Button>
                <Button x:Name="MaximizeButton" Width="46" Height="34"
                        Click="OnMaximizeClick" Background="Transparent">
                    <TextBlock x:Name="MaxIcon" Text="&#xE922;" FontFamily="{ThemeResource SymbolThemeFontFamily}"/>
                </Button>
                <Button x:Name="CloseButton" Width="46" Height="34" ToolTipService.ToolTip="关闭"
                        Click="OnCloseClick" Background="Transparent">
                    <TextBlock Text="&#xE8BB;" FontFamily="{ThemeResource SymbolThemeFontFamily}"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 导航 + 内容 -->
        <NavigationView x:Name="NavView" Grid.Row="1" PaneDisplayMode="LeftCompact"
                        IsSettingsVisible="False" IsBackButtonVisible="Collapsed"
                        OpenPaneLength="232" CompactPaneLength="48"
                        SelectionChanged="OnNavSelectionChanged"
                        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="NavDownload" Tag="download" IsSelected="True">
                    <NavigationViewItem.Content>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="下载任务" Margin="8,0,0,0"/>
                        </StackPanel>
                    </NavigationViewItem.Content>
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Download"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavHistory" Tag="history">
                    <NavigationViewItem.Content>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="历史记录" Margin="8,0,0,0"/>
                        </StackPanel>
                    </NavigationViewItem.Content>
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Clock"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavSettings" Tag="settings">
                    <NavigationViewItem.Content>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="设置" Margin="8,0,0,0"/>
                        </StackPanel>
                    </NavigationViewItem.Content>
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Setting"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame"/>
        </NavigationView>

        <!-- 状态栏 -->
        <Border Grid.Row="2" Background="{ThemeResource SystemChromeLowColor}" Padding="12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusLabel" Grid.Column="0" Text="就绪" VerticalAlignment="Center"
                           FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                <TextBlock x:Name="SpeedLabel" Grid.Column="1" Text="--" VerticalAlignment="Center"
                           FontSize="11" Margin="0,0,16,0"/>
                <TextBlock x:Name="DownloadCountLabel" Grid.Column="2" Text="0 个任务" VerticalAlignment="Center"
                           FontSize="12" Margin="0,0,16,0"/>
                <TextBlock x:Name="VersionLabel" Grid.Column="3" Text="v2.0.0" VerticalAlignment="Center"
                           FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                           PointerPressed="OnVersionClick"/>
            </Grid>
        </Border>

        <!-- 托盘图标 -->
        <notify:TaskbarIcon x:Name="TrayIcon"/>
    </Grid>
</Window>
