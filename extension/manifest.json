{
  "manifest_version": 3,
  "name": "TDM - TDSI Download Manager",
  "version": "1.0.0",
  "description": "拦截浏览器所有下载，发送到 TDSI Download Manager",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "nativeMessaging",
    "downloads",
    "downloads.ui",
    "storage",
    "activeTab",
    "webRequest",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "TDM - TDSI Download Manager",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["overlay.css", "overlay.js", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "minimum_chrome_version": "102"
}
