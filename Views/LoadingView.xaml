<UserControl x:Class="TDM.Views.LoadingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TDM"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="Transparent"
             IsHitTestVisible="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- 品牌标识 -->
            <Border Width="64" Height="64" CornerRadius="18"
                    Background="{StaticResource BrandGradientBrush}"
                    Effect="{StaticResource PrimaryGlow}"
                    HorizontalAlignment="Center" Margin="0,0,0,28">
                <TextBlock Text="T" FontFamily="{StaticResource UIFontFamily}"
                           FontSize="34" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- 转圈圈动画 -->
            <Grid Width="56" Height="56" HorizontalAlignment="Center" Margin="0,0,0,22">
                <Ellipse Width="56" Height="56" StrokeThickness="5"
                         Stroke="{StaticResource BorderBrush}" Opacity="0.55"/>
                <Ellipse x:Name="Spinner" Width="56" Height="56" StrokeThickness="5"
                         Stroke="{StaticResource PrimaryBrush}"
                         StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                         RenderTransformOrigin="0.5,0.5"
                         StrokeDashArray="110,200">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="SpinnerRotate" Angle="0"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
            </Grid>

            <!-- 标题与状态文字 -->
            <TextBlock x:Name="TitleText" Text="TDM"
                       FontFamily="{StaticResource UIFontFamily}"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
            <TextBlock x:Name="StatusText" Text="正在启动..."
                       FontFamily="{StaticResource UIFontFamily}"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
