<UserControl x:Class="TDM.Views.DownloadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:TDM.ViewModels"
             xmlns:conv="clr-namespace:TDM.Converters"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="700"
             Background="{StaticResource BackgroundBottomBrush}">
    <UserControl.Resources>
        <conv:BytesToStringConverter x:Key="BytesToStr"/>
        <conv:SpeedToStringConverter x:Key="SpeedToStr"/>
        <conv:SecondsToDurationConverter x:Key="SecsToDur"/>
        <conv:EtaConverter x:Key="Eta"/>
        <conv:PercentFormatConverter x:Key="PctFmt"/>
        <conv:StatusToBrushConverter x:Key="StatusToBrush"/>
        <conv:CountToVisibilityConverter x:Key="CountToVis"/>
    </UserControl.Resources>
    <UserControl.DataContext>
        <vm:DownloadViewModel/>
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 链接输入区 -->
            <RowDefinition Height="Auto"/>  <!-- 嗅探资源 -->
            <RowDefinition Height="Auto"/>  <!-- 保存选项 -->
            <RowDefinition Height="Auto"/>  <!-- 活动列表标题栏 -->
            <RowDefinition Height="*"/>     <!-- 活动列表（最少 240px） -->
        </Grid.RowDefinitions>

        <!-- 链接输入 -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="下载链接" Style="{StaticResource GroupTitle}" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="UrlTextBox"
                             Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}"
                             KeyDown="OnUrlKeyDown"
                             ToolTip="支持 http/https 链接；可拖放链接到窗口"/>
                    <Button Grid.Column="1" Style="{StaticResource FlatButton}" Content="粘贴"
                            Margin="8,0,0,0" Click="OnPasteClick"/>
                    <Button Grid.Column="2" Style="{StaticResource PrimaryButton}" Content="嗅探资源"
                            Margin="8,0,0,0" Command="{Binding SniffCommand}"/>
                </Grid>
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,16,0">
                        <Ellipse Width="6" Height="6" Fill="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="支持多线程断点续传" Style="{StaticResource SubText}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" Fill="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="智能嗅探网页资源" Style="{StaticResource SubText}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="完整下载历史" Style="{StaticResource SubText}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 嗅探资源 -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,12,0,0"
                Visibility="{Binding Resources.Count, Converter={StaticResource CountToVis}}">
            <StackPanel>
                <DockPanel>
                    <TextBlock Text="嗅探到的资源" Style="{StaticResource GroupTitle}" VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Right" Text="{Binding SniffStatus}" Style="{StaticResource SubText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                </DockPanel>
                <ListBox ItemsSource="{Binding Resources}" MaxHeight="150" Margin="0,8,0,0"
                         Background="Transparent" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding TypeIcon}" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Border Grid.Column="1" CornerRadius="3" Padding="6,2" Margin="0,0,8,0"
                                        Background="{Binding Type, Converter={StaticResource StatusToBrush}}">
                                    <TextBlock Text="{Binding Type}" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                </Border>
                                <TextBlock Grid.Column="2" Text="{Binding Filename}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                <Button Grid.Column="3" Style="{StaticResource FlatButton}" Content="下载"
                                        Command="{Binding DataContext.BrowseResourceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}" Padding="10,2" Margin="0,0,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- 保存选项 -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock Text="保存设置" Style="{StaticResource GroupTitle}" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="保存目录" Style="{StaticResource SubText}" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding SavePath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}"/>
                        <Button Grid.Column="1" Style="{StaticResource FlatButton}" Content="浏览…" Margin="8,0,0,0" Click="OnBrowseClick"/>
                    </Grid>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="线程数" Style="{StaticResource SubText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                        <Slider x:Name="ThreadsSlider" Minimum="1" Maximum="64" Value="{Binding Threads}" Width="180" VerticalAlignment="Center"
                                IsSnapToTickEnabled="True" TickFrequency="4" Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="{Binding Threads, StringFormat={}{0}}" VerticalAlignment="Center" Margin="10,0,20,0" FontWeight="SemiBold"/>
                        <TextBlock Text="重试次数" Style="{StaticResource SubText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider x:Name="RetriesSlider" Minimum="0" Maximum="10" Value="{Binding Retries}" Width="120" VerticalAlignment="Center"
                                IsSnapToTickEnabled="True" TickFrequency="1" Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="{Binding Retries, StringFormat={}{0}}" VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Style="{StaticResource PrimaryButton}" Content="开始下载" Command="{Binding StartCommand}" MinWidth="120"/>
                    <Button Style="{StaticResource FlatButton}" Content="打开下载目录" Margin="8,0,0,0" Click="OnOpenFolderClick"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 活动列表 -->
        <Border Grid.Row="3" Grid.RowSpan="2" Style="{StaticResource CardBorder}" Margin="0,12,0,0" MinHeight="280">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                    <TextBlock Text="活动任务" Style="{StaticResource GroupTitle}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ActiveItems.Count, StringFormat='（{0}）'}" Style="{StaticResource SubText}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource FlatButton}" Content="暂停" Command="{Binding PauseCommand}" Padding="10,4" Margin="0,0,6,0"/>
                        <Button Style="{StaticResource FlatButton}" Content="继续" Command="{Binding ResumeCommand}" Padding="10,4" Margin="0,0,6,0"/>
                        <Button Style="{StaticResource FlatButton}" Content="停止" Command="{Binding StopCommand}" Padding="10,4" Margin="0,0,6,0"/>
                        <Button Style="{StaticResource FlatButton}" Content="移除" Command="{Binding RemoveCommand}" Padding="10,4"/>
                    </StackPanel>
                </DockPanel>
                <DataGrid ItemsSource="{Binding ActiveItems}" SelectedItem="{Binding SelectedItem}"
                          MinHeight="220"
                          Style="{StaticResource ModernDataGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="文件名" Binding="{Binding FileName}" Width="*"/>
                        <DataGridTextColumn Header="大小" Binding="{Binding TotalSize, Converter={StaticResource BytesToStr}}" Width="100"/>
                        <DataGridTemplateColumn Header="状态" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="3" Padding="6,2" HorizontalAlignment="Left"
                                            Background="{Binding StatusText, Converter={StaticResource StatusToBrush}}">
                                        <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="进度" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center">
                                        <ProgressBar Value="{Binding Progress}" Maximum="100" Height="8"
                                                     Background="#22000000" BorderThickness="0"
                                                     Foreground="{StaticResource PrimaryGradientBrush}"/>
                                        <TextBlock Text="{Binding Progress, StringFormat='{}{0:0.#}%'}" FontSize="10" Margin="0,2,0,0" Foreground="{StaticResource SubTextBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="速度" Binding="{Binding Speed, Converter={StaticResource SpeedToStr}}" Width="100"/>
                        <DataGridTemplateColumn Header="剩余时间" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock VerticalAlignment="Center">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource Eta}">
                                                <Binding Path="TotalSize"/>
                                                <Binding Path="DownloadedBytes"/>
                                                <Binding Path="Speed"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
