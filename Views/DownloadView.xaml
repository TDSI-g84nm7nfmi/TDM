<UserControl x:Class="TDM.Views.DownloadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:TDM.ViewModels"
             xmlns:conv="clr-namespace:TDM.Converters"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1100"
             Background="Transparent">
    <UserControl.Resources>
        <conv:BytesToStringConverter x:Key="BytesToStr"/>
        <conv:SpeedToStringConverter x:Key="SpeedToStr"/>
        <conv:SecondsToDurationConverter x:Key="SecsToDur"/>
        <conv:EtaConverter x:Key="Eta"/>
        <conv:PercentFormatConverter x:Key="PctFmt"/>
        <conv:StatusToBrushConverter x:Key="StatusToBrush"/>
        <conv:CountToVisibilityConverter x:Key="CountToVis"/>
    </UserControl.Resources>
    <UserControl.DataContext>
        <vm:DownloadViewModel/>
    </UserControl.DataContext>

    <Grid Margin="20,18,20,14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="380"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*" MinWidth="420"/>
        </Grid.ColumnDefinitions>

        <!-- ====================== 左侧：控制区 ====================== -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- 标题 -->
                <RowDefinition Height="Auto"/>  <!-- 统计 -->
                <RowDefinition Height="Auto"/>  <!-- URL + 操作 -->
                <RowDefinition Height="Auto"/>  <!-- 嗅探资源 -->
                <RowDefinition Height="*"/>     <!-- 保存设置 -->
            </Grid.RowDefinitions>

            <!-- 标题 -->
            <StackPanel Grid.Row="0" Margin="4,0,4,16">
                <TextBlock Text="下载任务" Style="{StaticResource H1}"/>
                <TextBlock Text="添加新任务、管理活动下载与设置" Style="{StaticResource BodySecondary}" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- 统计仪表板 4 个数据卡 -->
            <Grid Grid.Row="1" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,4,4" Padding="16,14">
                    <StackPanel>
                        <DockPanel>
                            <Border Width="32" Height="32" CornerRadius="9" Background="#1A4F8BFF" DockPanel.Dock="Left">
                                <Path Width="16" Height="16" Stretch="Uniform" Fill="{StaticResource PrimaryBrush}"
                                      Data="{StaticResource IconDownload}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="进行中" Style="{StaticResource SubText}" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                        </DockPanel>
                        <TextBlock x:Name="StatRunning" Text="0" FontFamily="{StaticResource UIFontFamily}"
                                   FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CardBorder}" Margin="4,0,0,4" Padding="16,14">
                    <StackPanel>
                        <DockPanel>
                            <Border Width="32" Height="32" CornerRadius="9" Background="#1A1BC982" DockPanel.Dock="Left">
                                <Path Width="16" Height="16" Stretch="Uniform" Fill="{StaticResource SuccessBrush}"
                                      Data="{StaticResource IconCheck}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="已完成" Style="{StaticResource SubText}" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                        </DockPanel>
                        <TextBlock x:Name="StatCompleted" Text="0" FontFamily="{StaticResource UIFontFamily}"
                                   FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,4,4,0" Padding="16,14">
                    <StackPanel>
                        <DockPanel>
                            <Border Width="32" Height="32" CornerRadius="9" Background="#1AFF5C6B" DockPanel.Dock="Left">
                                <Path Width="16" Height="16" Stretch="Uniform" Stroke="{StaticResource ErrorBrush}" StrokeThickness="2" Fill="Transparent"
                                      Data="{StaticResource IconCancel}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="失败" Style="{StaticResource SubText}" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                        </DockPanel>
                        <TextBlock x:Name="StatFailed" Text="0" FontFamily="{StaticResource UIFontFamily}"
                                   FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardBorder}" Margin="4,4,0,0" Padding="16,14">
                    <StackPanel>
                        <DockPanel>
                            <Border Width="32" Height="32" CornerRadius="9" Background="#1A6EC6FF" DockPanel.Dock="Left">
                                <Path Width="16" Height="16" Stretch="Uniform" Fill="{StaticResource AccentBrush}"
                                      Data="{StaticResource IconSpeed}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="实时速度" Style="{StaticResource SubText}" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                        </DockPanel>
                        <TextBlock x:Name="StatSpeed" Text="0 B/s" FontFamily="{StaticResource MonoFontFamily}"
                                   FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- URL 输入 + 嗅探 -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="16,14" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="新建下载" Style="{StaticResource GroupTitle}" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="UrlTextBox"
                                 Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 KeyDown="OnUrlKeyDown"
                                 ToolTip="支持 http/https 链接；可拖放链接到窗口"/>
                        <Button Grid.Column="1" Style="{StaticResource GhostButton}" Margin="6,0,0,0"
                                Click="OnPasteClick" Padding="10,5">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Width="14" Height="14" Stretch="Uniform" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Fill="Transparent" Data="{StaticResource IconPaste}" Margin="0,0,5,0"/>
                                <TextBlock Text="粘贴" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Margin="6,0,0,0"
                                Command="{Binding SniffCommand}" Padding="10,5">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Width="14" Height="14" Stretch="Uniform" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Fill="Transparent" Data="{StaticResource IconSniff}" Margin="0,0,5,0"/>
                                <TextBlock Text="嗅探资源" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="3" Style="{StaticResource PrimaryButton}" Margin="6,0,0,0"
                                Command="{Binding StartCommand}" MinWidth="96" Padding="14,5">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Width="14" Height="14" Stretch="Uniform" Stroke="White" StrokeThickness="1.8" Fill="Transparent" Data="{StaticResource IconDownload}" Margin="0,0,5,0"/>
                                <TextBlock Text="开始下载" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 嗅探资源 -->
            <Border Grid.Row="3" Style="{StaticResource CardBorder}" Padding="16,14" Margin="0,0,0,14"
                    Visibility="{Binding Resources.Count, Converter={StaticResource CountToVis}}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="嗅探到的资源" Style="{StaticResource GroupTitle}" VerticalAlignment="Center"/>
                        <TextBlock DockPanel.Dock="Right" Text="{Binding SniffStatus}" Style="{StaticResource SubText}" VerticalAlignment="Center"/>
                    </DockPanel>
                    <ListBox ItemsSource="{Binding Resources}" MaxHeight="140"
                             Background="Transparent" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" CornerRadius="4" Padding="6,2" Margin="0,0,8,0"
                                            Background="{Binding Type, Converter={StaticResource StatusToBrush}}">
                                        <TextBlock Text="{Binding Type}" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding Filename}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                    <Button Grid.Column="2" Style="{StaticResource GhostButton}"
                                            Command="{Binding DataContext.BrowseResourceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" Padding="8,2" Margin="6,0,0,0">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Width="12" Height="12" Stretch="Uniform" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Data="{StaticResource IconDownload}" Margin="0,0,4,0"/>
                                            <TextBlock Text="下载" VerticalAlignment="Center" FontSize="12"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- 支持的协议提示 -->
            <Border Grid.Row="4" Style="{StaticResource CardBorder}" Padding="16,14" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="支持的协议" Style="{StaticResource GroupTitle}" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="28" Height="28" CornerRadius="7" Background="#1A4F8BFF" Margin="0,0,8,0">
                                <Path Width="14" Height="14" Stretch="Uniform" Fill="{StaticResource PrimaryBrush}"
                                      Data="{StaticResource IconLink}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="HTTP / HTTPS" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="多线程分片" FontSize="10" Foreground="{StaticResource SubTextBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="28" Height="28" CornerRadius="7" Background="#1A1BC982" Margin="0,0,8,0">
                                <Path Width="14" Height="14" Stretch="Uniform" Fill="{StaticResource SuccessBrush}"
                                      Data="{StaticResource IconTorrent}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="BT 种子" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text=".torrent / magnet:" FontSize="10" Foreground="{StaticResource SubTextBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="28" Height="28" CornerRadius="7" Background="#1A6EC6FF" Margin="0,0,8,0">
                                <Path Width="14" Height="14" Stretch="Uniform" Fill="{StaticResource AccentBrush}"
                                      Data="{StaticResource IconMagnet}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="电驴链接" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="ed2k://" FontSize="10" Foreground="{StaticResource SubTextBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    <Button Style="{StaticResource SecondaryButton}" Command="{Binding OpenTorrentCommand}"
                            HorizontalAlignment="Stretch" Margin="0,12,0,0" Padding="0,8">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Path Width="14" Height="14" Stretch="Uniform" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Data="{StaticResource IconTorrent}" Margin="0,0,6,0"/>
                            <TextBlock Text="打开 .torrent 种子文件…" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ====================== 分割条 ====================== -->
        <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Background="Transparent" ShowsPreview="False" ResizeBehavior="PreviousAndNext"
                      Margin="2,0" Cursor="SizeWE">
            <GridSplitter.Template>
                <ControlTemplate TargetType="GridSplitter">
                    <Border Background="Transparent" Width="6">
                        <Rectangle Width="1" Fill="{StaticResource DividerBrush}" HorizontalAlignment="Center" Opacity="0.6"/>
                    </Border>
                </ControlTemplate>
            </GridSplitter.Template>
        </GridSplitter>

        <!-- ====================== 右侧：活动任务栏 ====================== -->
        <Border Grid.Column="2" Style="{StaticResource CardBorder}" Padding="0">
            <DockPanel>
                <!-- 标题栏 -->
                <Border DockPanel.Dock="Top" Padding="18,14,14,14" BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="28" Height="28" CornerRadius="8" Background="#1A4F8BFF">
                                    <Path Width="14" Height="14" Stretch="Uniform" Fill="{StaticResource PrimaryBrush}"
                                          Data="{StaticResource IconDownload}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="活动任务" Style="{StaticResource GroupTitle}" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="15"/>
                                <TextBlock Text="{Binding ActiveItems.Count, StringFormat='（{0}）'}" Style="{StaticResource SubText}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                            </StackPanel>
                        </DockPanel>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0">
                            <Button Style="{StaticResource GhostButton}" Command="{Binding PauseCommand}" Padding="10,4" Margin="0,0,4,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Path Width="12" Height="12" Stretch="Uniform" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Fill="Transparent" Data="{StaticResource IconPause}" Margin="0,0,4,0"/>
                                    <TextBlock Text="暂停" VerticalAlignment="Center" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource GhostButton}" Command="{Binding ResumeCommand}" Padding="10,4" Margin="0,0,4,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Path Width="12" Height="12" Stretch="Uniform" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Data="{StaticResource IconResume}" Margin="0,0,4,0"/>
                                    <TextBlock Text="继续" VerticalAlignment="Center" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource GhostButton}" Command="{Binding StopCommand}" Padding="10,4" Margin="0,0,4,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Path Width="12" Height="12" Stretch="Uniform" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Data="{StaticResource IconStop}" Margin="0,0,4,0"/>
                                    <TextBlock Text="停止" VerticalAlignment="Center" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource DangerButton}" Command="{Binding RemoveCommand}" Padding="10,4" Margin="0,0,4,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Path Width="12" Height="12" Stretch="Uniform" Fill="White" Data="{StaticResource IconTrash}" Margin="0,0,4,0"/>
                                    <TextBlock Text="移除" VerticalAlignment="Center" FontSize="12"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 任务列表 + 空状态叠加 -->
                <Grid>
                    <DataGrid ItemsSource="{Binding ActiveItems}" SelectedItem="{Binding SelectedItem}"
                              Background="Transparent" BorderThickness="0" RowHeight="56"
                              Style="{StaticResource ModernDataGrid}"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              AutoGenerateColumns="False" HeadersVisibility="Column"
                              GridLinesVisibility="None" CanUserAddRows="False">
                        <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="44">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="6" Padding="6,2" HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Background="{Binding ProtocolText, Converter={StaticResource StatusToBrush}}"
                                            ToolTip="{Binding ProtocolText}">
                                        <TextBlock Text="{Binding ProtocolText}" Foreground="White" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="任务" Width="*" MinWidth="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center" Margin="2,0">
                                            <TextBlock Text="{Binding FileName}" FontSize="13" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" Foreground="{StaticResource TextBrush}"/>
                                            <TextBlock Text="{Binding Url}" FontSize="10" Opacity="0.6"
                                                       TextTrimming="CharacterEllipsis" Foreground="{StaticResource SubTextBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="状态" Width="86">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10" Padding="8,2" HorizontalAlignment="Left" VerticalAlignment="Center"
                                                Background="{Binding StatusText, Converter={StaticResource StatusToBrush}}">
                                            <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="进度" Width="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center">
                                            <ProgressBar Value="{Binding Progress}" Maximum="100" Height="6"
                                                         Background="#22000000" BorderThickness="0"
                                                         Foreground="{StaticResource PrimaryGradientBrush}"/>
                                            <Grid Margin="0,3,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Progress, StringFormat='{}{0:0.#}%'}" FontSize="10"
                                                           Foreground="{StaticResource SubTextBrush}"/>
                                                <TextBlock Grid.Column="1" HorizontalAlignment="Right" FontSize="10"
                                                           Foreground="{StaticResource SubTextBrush}" FontFamily="{StaticResource MonoFontFamily}"
                                                           Text="{Binding DownloadedBytes, Converter={StaticResource BytesToStr}}"/>
                                            </Grid>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="速度" Binding="{Binding Speed, Converter={StaticResource SpeedToStr}}" Width="86">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontFamily" Value="{StaticResource MonoFontFamily}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="剩余" Width="68">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock VerticalAlignment="Center" FontFamily="{StaticResource MonoFontFamily}" FontSize="11">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource Eta}">
                                                    <Binding Path="TotalSize"/>
                                                    <Binding Path="DownloadedBytes"/>
                                                    <Binding Path="Speed"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- 空状态（叠加在 DataGrid 之上） -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40,0,40" IsHitTestVisible="False"
                                Visibility="{Binding ActiveItems.Count, Converter={StaticResource CountToVis}, ConverterParameter=Invert}">
                        <Border Width="72" Height="72" CornerRadius="36" Background="#104F8BFF" HorizontalAlignment="Center">
                            <Path Width="32" Height="32" Stretch="Uniform" Fill="{StaticResource PrimaryBrush}"
                                  Data="{StaticResource IconDownload}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="暂无活动任务" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" Margin="0,14,0,4"/>
                        <TextBlock Text="在左侧添加链接即可开始下载" FontSize="12"
                                   Foreground="{StaticResource SubTextBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
