<UserControl x:Class="TDM.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:TDM.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="700"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20,24,16">
        <StackPanel MaxWidth="720" HorizontalAlignment="Stretch">
            <!-- 标题 -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="设置" Style="{StaticResource H1}"/>
                <TextBlock Text="个性化 TDM 的外观与行为" Style="{StaticResource BodySecondary}" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- 主题 -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,14" Padding="22,18">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Width="16" Height="16" Stretch="Uniform" Fill="{StaticResource PrimaryBrush}" Data="{StaticResource IconPalette}" Margin="0,0,8,0"/>
                            <TextBlock Text="主题" Style="{StaticResource GroupTitle}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock DockPanel.Dock="Right" Text="切换后立即生效" Style="{StaticResource SubText}" VerticalAlignment="Center"/>
                    </DockPanel>
                    <ItemsControl>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <RadioButton Style="{StaticResource ModernRadioButton}" GroupName="Theme" Content="蓝色" Margin="0,0,18,8" Checked="OnThemeChanged" Tag="blue"/>
                        <RadioButton Style="{StaticResource ModernRadioButton}" GroupName="Theme" Content="绿色" Margin="0,0,18,8" Checked="OnThemeChanged" Tag="green"/>
                        <RadioButton Style="{StaticResource ModernRadioButton}" GroupName="Theme" Content="紫色" Margin="0,0,18,8" Checked="OnThemeChanged" Tag="purple"/>
                        <RadioButton Style="{StaticResource ModernRadioButton}" GroupName="Theme" Content="粉色" Margin="0,0,18,8" Checked="OnThemeChanged" Tag="pink"/>
                        <RadioButton Style="{StaticResource ModernRadioButton}" GroupName="Theme" Content="深色" Margin="0,0,0,8" Checked="OnThemeChanged" Tag="dark"/>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- 下载 -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,14" Padding="22,18">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Path Width="16" Height="16" Stretch="Uniform" Stroke="{StaticResource PrimaryBrush}" StrokeThickness="1.8" Fill="Transparent" Data="{StaticResource IconDownload}" Margin="0,0,8,0"/>
                        <TextBlock Text="下载" Style="{StaticResource GroupTitle}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="默认保存目录" Style="{StaticResource BodySecondary}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding DefaultSaveDir, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}"/>
                        <Button Grid.Column="2" Style="{StaticResource GhostButton}" Margin="8,0,0,0" Command="{Binding BrowseCommand}" Padding="12,6">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Width="14" Height="14" Stretch="Uniform" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Data="{StaticResource IconFolder}" Margin="0,0,5,0"/>
                                <TextBlock Text="浏览…" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="默认线程数" Style="{StaticResource BodySecondary}" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" Minimum="1" Maximum="64" Value="{Binding DefaultThreads}" VerticalAlignment="Center"
                                IsSnapToTickEnabled="True" TickFrequency="4" Style="{StaticResource ModernSlider}"/>
                        <TextBlock Grid.Column="2" Text="{Binding DefaultThreads}" VerticalAlignment="Center" Margin="12,0,0,0"
                                   FontFamily="{StaticResource MonoFontFamily}" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" MinWidth="32"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="重试次数" Style="{StaticResource BodySecondary}" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" Minimum="0" Maximum="10" Value="{Binding MaxRetries}" VerticalAlignment="Center"
                                IsSnapToTickEnabled="True" TickFrequency="1" Style="{StaticResource ModernSlider}"/>
                        <TextBlock Grid.Column="2" Text="{Binding MaxRetries}" VerticalAlignment="Center" Margin="12,0,0,0"
                                   FontFamily="{StaticResource MonoFontFamily}" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" MinWidth="32"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="分块大小" Style="{StaticResource BodySecondary}" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" Minimum="8" Maximum="1024" Value="{Binding ChunkSizeKB}" VerticalAlignment="Center"
                                IsSnapToTickEnabled="False" Style="{StaticResource ModernSlider}"/>
                        <TextBlock Grid.Column="2" Text="{Binding ChunkSizeKB, StringFormat='{}{0} KB'}" VerticalAlignment="Center" Margin="12,0,0,0"
                                   FontFamily="{StaticResource MonoFontFamily}" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" MinWidth="60"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 行为 -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,14" Padding="22,18">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Path Width="16" Height="16" Stretch="Uniform" Stroke="{StaticResource PrimaryBrush}" StrokeThickness="1.8" Fill="Transparent" Data="{StaticResource IconSpeed}" Margin="0,0,8,0"/>
                        <TextBlock Text="行为" Style="{StaticResource GroupTitle}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <CheckBox Style="{StaticResource ModernCheckBox}" Content="自动检测剪贴板中的下载链接"
                              IsChecked="{Binding EnableClipboard}" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="点击关闭按钮时" Style="{StaticResource BodySecondary}" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" x:Name="CloseActionBox" Width="200"
                                  SelectedValue="{Binding CloseAction}" SelectedValuePath="Tag" SelectionChanged="OnCloseActionChanged">
                            <ComboBoxItem Content="每次询问" Tag="ask"/>
                            <ComboBoxItem Content="最小化到托盘" Tag="tray"/>
                            <ComboBoxItem Content="直接退出" Tag="exit"/>
                        </ComboBox>
                    </Grid>
                    <CheckBox Style="{StaticResource ModernCheckBox}" Content="下载完成时显示通知"
                              IsChecked="{Binding NotifyFinished}" Margin="0,0,0,10"/>
                    <CheckBox Style="{StaticResource ModernCheckBox}" Content="下载出错时显示通知"
                              IsChecked="{Binding NotifyError}" Margin="0,0,0,10"/>
                    <CheckBox Style="{StaticResource ModernCheckBox}" Content="启用毛玻璃效果（需要 Windows 10/11）"
                              IsChecked="{Binding AcrylicBlur}"/>
                </StackPanel>
            </Border>

            <!-- 浏览器扩展 -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,14" Padding="22,18">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Path Width="16" Height="16" Stretch="Uniform" Stroke="{StaticResource PrimaryBrush}" StrokeThickness="1.8" Fill="Transparent" Data="{StaticResource IconBrowser}" Margin="0,0,8,0"/>
                        <TextBlock Text="浏览器扩展" Style="{StaticResource GroupTitle}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10" LineHeight="20">
                        TDM 启动时会自动扫描系统中的 Chromium 内核浏览器（Chrome、Edge、Tabbit、Brave、Vivaldi、Opera、360 极速、QQ 浏览器、Yandex、Cent Browser 等），询问是否安装扩展接管所有下载。
                    </TextBlock>
                    <CheckBox x:Name="ScanOnStartupCheck" Content="启动时自动扫描浏览器"
                              IsChecked="{Binding ScanBrowsersOnStartup}" Margin="0,0,0,10" Style="{StaticResource ModernCheckBox}"/>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="RescanBrowserButton" Style="{StaticResource SecondaryButton}" Click="OnRescanBrowser" Padding="14,8" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Width="14" Height="14" Stretch="Uniform" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Fill="Transparent" Data="{StaticResource IconRefresh}" Margin="0,0,6,0"/>
                                <TextBlock Text="重新扫描浏览器" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="OpenLogWindowButton" Style="{StaticResource GhostButton}" Click="OnOpenLogWindow" Padding="14,8">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Width="14" Height="14" Stretch="Uniform" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Fill="Transparent" Data="{StaticResource IconLog}" Margin="0,0,6,0"/>
                                <TextBlock Text="打开实时日志" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 高级 -->
            <Border Style="{StaticResource CardBorder}" Padding="22,18">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Path Width="16" Height="16" Stretch="Uniform" Stroke="{StaticResource PrimaryBrush}" StrokeThickness="1.8" Fill="Transparent" Data="{StaticResource IconLog}" Margin="0,0,8,0"/>
                        <TextBlock Text="高级" Style="{StaticResource GroupTitle}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <WrapPanel>
                        <Button Style="{StaticResource SecondaryButton}" Command="{Binding OpenDataFolderCommand}" Margin="0,0,8,8" Padding="14,8">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Width="14" Height="14" Stretch="Uniform" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Data="{StaticResource IconFolder}" Margin="0,0,6,0"/>
                                <TextBlock Text="打开数据目录" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SecondaryButton}" Command="{Binding OpenLogFolderCommand}" Margin="0,0,8,8" Padding="14,8">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Width="14" Height="14" Stretch="Uniform" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Data="{StaticResource IconLog}" Margin="0,0,6,0"/>
                                <TextBlock Text="打开日志目录" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SecondaryButton}" Command="{Binding ClearHistoryCommand}" Margin="0,0,8,8" Padding="14,8">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Width="14" Height="14" Stretch="Uniform" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Fill="Transparent" Data="{StaticResource IconTrash}" Margin="0,0,6,0"/>
                                <TextBlock Text="清空历史记录" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource DangerButton}" Command="{Binding ResetSettingsCommand}" Padding="14,8">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Width="14" Height="14" Stretch="Uniform" Stroke="White" StrokeThickness="1.8" Fill="Transparent" Data="{StaticResource IconRefresh}" Margin="0,0,6,0"/>
                                <TextBlock Text="重置所有设置" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>