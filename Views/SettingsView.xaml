<UserControl x:Class="TDM.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:TDM.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="700"
             Background="{StaticResource BackgroundBottomBrush}">
    <UserControl.DataContext>
        <vm:SettingsViewModel/>
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel MaxWidth="640" HorizontalAlignment="Stretch">
            <TextBlock Text="设置" FontFamily="{StaticResource UIFontFamily}" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>

            <!-- 主题 -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="主题" Style="{StaticResource GroupTitle}" Margin="0,0,0,10"/>
                    <ItemsControl>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <RadioButton x:Name="PurpleTheme" Style="{StaticResource ModernRadioButton}"
                                     GroupName="Theme" Content="紫色（默认）" Margin="0,0,16,8"
                                     Checked="OnThemeChanged" Tag="purple"/>
                        <RadioButton Style="{StaticResource ModernRadioButton}"
                                     GroupName="Theme" Content="蓝色" Margin="0,0,16,8"
                                     Checked="OnThemeChanged" Tag="blue"/>
                        <RadioButton Style="{StaticResource ModernRadioButton}"
                                     GroupName="Theme" Content="绿色" Margin="0,0,16,8"
                                     Checked="OnThemeChanged" Tag="green"/>
                        <RadioButton Style="{StaticResource ModernRadioButton}"
                                     GroupName="Theme" Content="粉色" Margin="0,0,16,8"
                                     Checked="OnThemeChanged" Tag="pink"/>
                        <RadioButton Style="{StaticResource ModernRadioButton}"
                                     GroupName="Theme" Content="深色" Margin="0,0,16,8"
                                     Checked="OnThemeChanged" Tag="dark"/>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- 下载 -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="下载" Style="{StaticResource GroupTitle}" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="默认保存目录" Style="{StaticResource SubText}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding DefaultSaveDir, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}"/>
                        <Button Grid.Column="2" Style="{StaticResource FlatButton}" Content="浏览…" Margin="8,0,0,0" Command="{Binding BrowseCommand}"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="默认线程数" Style="{StaticResource SubText}" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Slider Minimum="1" Maximum="64" Value="{Binding DefaultThreads}" Width="200" VerticalAlignment="Center"
                                    IsSnapToTickEnabled="True" TickFrequency="4" Foreground="{StaticResource PrimaryBrush}"/>
                            <TextBlock Text="{Binding DefaultThreads}" VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="重试次数" Style="{StaticResource SubText}" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Slider Minimum="0" Maximum="10" Value="{Binding MaxRetries}" Width="200" VerticalAlignment="Center"
                                    IsSnapToTickEnabled="True" TickFrequency="1" Foreground="{StaticResource PrimaryBrush}"/>
                            <TextBlock Text="{Binding MaxRetries}" VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="分块大小" Style="{StaticResource SubText}" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Slider Minimum="8" Maximum="1024" Value="{Binding ChunkSizeKB}" Width="200" VerticalAlignment="Center"
                                    IsSnapToTickEnabled="False" Foreground="{StaticResource PrimaryBrush}"/>
                            <TextBlock Text="{Binding ChunkSizeKB, StringFormat='{}{0} KB'}" VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 行为 -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="行为" Style="{StaticResource GroupTitle}" Margin="0,0,0,10"/>
                    <CheckBox Style="{StaticResource ModernCheckBox}" Content="自动检测剪贴板中的下载链接"
                              IsChecked="{Binding EnableClipboard}" Margin="0,0,0,8"/>
                    <CheckBox Style="{StaticResource ModernCheckBox}" Content="关闭窗口时最小化到系统托盘"
                              IsChecked="{Binding MinimizeToTray}" Margin="0,0,0,8"/>
                    <CheckBox Style="{StaticResource ModernCheckBox}" Content="下载完成时显示通知"
                              IsChecked="{Binding NotifyFinished}" Margin="0,0,0,8"/>
                    <CheckBox Style="{StaticResource ModernCheckBox}" Content="下载出错时显示通知"
                              IsChecked="{Binding NotifyError}" Margin="0,0,0,8"/>
                    <CheckBox Style="{StaticResource ModernCheckBox}" Content="启用毛玻璃效果（需要 Windows 10/11）"
                              IsChecked="{Binding AcrylicBlur}"/>
                </StackPanel>
            </Border>

            <!-- 高级 -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="高级" Style="{StaticResource GroupTitle}" Margin="0,0,0,10"/>
                    <WrapPanel>
                        <Button Style="{StaticResource FlatButton}" Content="打开数据目录" Command="{Binding OpenDataFolderCommand}" Margin="0,0,8,8" Padding="14,6"/>
                        <Button Style="{StaticResource FlatButton}" Content="打开日志目录" Command="{Binding OpenLogFolderCommand}" Margin="0,0,8,8" Padding="14,6"/>
                        <Button Style="{StaticResource FlatButton}" Content="清空历史记录" Command="{Binding ClearHistoryCommand}" Margin="0,0,8,8" Padding="14,6"/>
                        <Button Style="{StaticResource FlatButton}" Content="重置所有设置" Command="{Binding ResetSettingsCommand}" Padding="14,6"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- 浏览器扩展 -->
            <Border Style="{StaticResource CardBorder}" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="浏览器扩展" Style="{StaticResource GroupTitle}" Margin="0,0,0,10"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource SubTextBrush}" FontSize="12" Margin="0,0,0,8">
                        TDM 启动时会自动扫描系统中的 Chromium 内核浏览器（Chrome、Edge、Tabbit、Brave、Vivaldi、Opera、360 极速、QQ 浏览器、Yandex、Cent Browser 等），询问是否安装扩展接管所有下载。
                    </TextBlock>
                    <CheckBox x:Name="ScanOnStartupCheck" Content="启动时自动扫描浏览器" IsChecked="{Binding ScanBrowsersOnStartup}" Margin="0,0,0,8" Style="{StaticResource ModernCheckBox}"/>
                    <WrapPanel>
                        <Button x:Name="RescanBrowserButton" Style="{StaticResource FlatButton}" Content="重新扫描浏览器" Click="OnRescanBrowser" Padding="14,6" Margin="0,0,8,0"/>
                        <Button x:Name="OpenLogWindowButton" Style="{StaticResource FlatButton}" Content="打开实时日志（开发者模式）" Click="OnOpenLogWindow" Padding="14,6"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
