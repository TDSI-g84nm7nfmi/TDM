<Page x:Class="TDM.Views.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="16">
        <ScrollViewer>
            <StackPanel Spacing="12">
                <TextBlock Text="设置" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8"/>

                <TextBlock Text="下载目录" FontWeight="SemiBold"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="DownloadPathBox" IsReadOnly="True" Height="32"/>
                    <Button Grid.Column="1" Content="浏览" Click="OnBrowsePathClick" Margin="8,0,0,0"/>
                </Grid>

                <TextBlock Text="下载线程数" FontWeight="SemiBold"/>
                <Slider x:Name="ThreadSlider" Minimum="1" Maximum="32" Value="8" Width="240"/>

                <TextBlock Text="最大下载速度 (KB/s, 0=不限)" FontWeight="SemiBold"/>
                <TextBox x:Name="SpeedLimitBox" Text="0" Width="120"/>

                <Button Content="保存设置" Click="OnSaveClick" HorizontalAlignment="Left" Margin="0,12,0,0"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
