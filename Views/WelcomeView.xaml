<UserControl x:Class="TDM.Views.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TDM.ViewModels"
             Background="{StaticResource BackgroundTopBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel HorizontalAlignment="Center" Margin="0,40,0,40" MaxWidth="600">
            
            <!-- Logo + 标题 -->
            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,32">
                <Image Width="72" Height="72" Margin="0,0,0,12" RenderOptions.BitmapScalingMode="HighQuality">
                    <Image.Source>
                        <BitmapImage UriSource="pack://application:,,,/image/icon.ico" DecodePixelWidth="72"/>
                    </Image.Source>
                </Image>
                <TextBlock Text="TDSI Download Manager" FontSize="28" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="现代化多线程下载管理器" FontSize="14"
                           Foreground="{StaticResource SubTextBrush}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>

            <!-- 功能卡片 -->
            <Border Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="⬇" FontSize="28" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="多线程下载" FontWeight="SemiBold" FontSize="15" Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="支持分片下载、断点续传，默认 32 线程高速下载" FontSize="12" Foreground="{StaticResource SubTextBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🔍" FontSize="28" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="智能嗅探" FontWeight="SemiBold" FontSize="15" Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="粘贴网页链接即可自动提取可下载资源（图片、视频、音频、文件）" FontSize="12" Foreground="{StaticResource SubTextBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🎨" FontSize="28" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="多主题 + 毛玻璃" FontWeight="SemiBold" FontSize="15" Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="支持淡蓝、紫色、深色等多套主题，配合毛玻璃效果，界面更现代" FontSize="12" Foreground="{StaticResource SubTextBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="📋" FontSize="28" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="剪贴板监控" FontWeight="SemiBold" FontSize="15" Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="自动检测剪贴板中的下载链接，一键开始下载" FontSize="12" Foreground="{StaticResource SubTextBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 开始使用提示 -->
            <Border Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,0"
                    Background="{StaticResource PrimaryBrush}" BorderBrush="Transparent">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="点击左侧「下载」开始使用" FontSize="14" FontWeight="SemiBold"
                               Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="或直接粘贴链接到 URL 输入框" FontSize="11"
                               Foreground="#CCFFFFFF" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>