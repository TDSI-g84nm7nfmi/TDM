<UserControl x:Class="TDM.Views.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TDM.ViewModels"
             xmlns:local="clr-namespace:TDM"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="32,32,32,32" MaxWidth="780" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 头部 Hero -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,36">
                <Border Width="84" Height="84" CornerRadius="22"
                        Background="{StaticResource BrandGradientBrush}"
                        Effect="{StaticResource PrimaryGlow}"
                        HorizontalAlignment="Center" Margin="0,0,0,20">
                    <TextBlock Text="T" FontFamily="{StaticResource UIFontFamily}"
                               FontSize="46" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="TDSI Download Manager" Style="{StaticResource H1}" HorizontalAlignment="Center"/>
                <TextBlock Text="现代化多线程下载管理器 · v" HorizontalAlignment="Center"
                           Style="{StaticResource BodySecondary}" Margin="0,6,0,0">
                    <Run Text="v"/>
                    <Run Text="{x:Static local:App.AppVersion}"/>
                </TextBlock>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
                    <Border CornerRadius="14" Padding="12,5" Background="#1A4F8BFF" Margin="0,0,8,0">
                        <TextBlock Text="多线程" Foreground="{StaticResource PrimaryBrush}" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                    <Border CornerRadius="14" Padding="12,5" Background="#1A1BC982" Margin="0,0,8,0">
                        <TextBlock Text="断点续传" Foreground="{StaticResource SuccessBrush}" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                    <Border CornerRadius="14" Padding="12,5" Background="#1A6EC6FF" Margin="0,0,8,0">
                        <TextBlock Text="智能嗅探" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                    <Border CornerRadius="14" Padding="12,5" Background="#1AA78BFA">
                        <TextBlock Text="毛玻璃" Foreground="{StaticResource Accent2Brush}" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </StackPanel>

            <!-- 功能卡 2x2 网格 -->
            <UniformGrid Grid.Row="1" Columns="2" Rows="2" Margin="0,0,0,16">
                <!-- 多线程下载 -->
                <Border Style="{StaticResource CardBorder}" Padding="22" Margin="0,0,8,8">
                    <StackPanel>
                        <Border Width="44" Height="44" CornerRadius="12" Background="#1A4F8BFF" HorizontalAlignment="Left" Margin="0,0,0,12">
                            <Path Width="22" Height="22" Stretch="Uniform" Fill="{StaticResource PrimaryBrush}"
                                  Data="M12,3 v10 M7,9 l5,5 5,-5 M5,21 h14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="多线程下载" FontWeight="SemiBold" FontSize="15" Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="支持分片下载、断点续传，默认 32 线程高速下载" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- 智能嗅探 -->
                <Border Style="{StaticResource CardBorder}" Padding="22" Margin="8,0,0,8">
                    <StackPanel>
                        <Border Width="44" Height="44" CornerRadius="12" Background="#1A1BC982" HorizontalAlignment="Left" Margin="0,0,0,12">
                            <Path Width="22" Height="22" Stretch="Uniform" Fill="{StaticResource SuccessBrush}"
                                  Data="M11,3 a8,8 0 1 0 4,14 l5,5 2,-2 -5,-5 a8,8 0 0 0 -6,-12 z M11,5 a6,6 0 1 1 0,12 a6,6 0 0 1 0,-12 z" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="智能嗅探" FontWeight="SemiBold" FontSize="15" Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="粘贴网页链接即可自动提取可下载资源（图片、视频、音频、文件）" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- 多主题 -->
                <Border Style="{StaticResource CardBorder}" Padding="22" Margin="0,8,8,0">
                    <StackPanel>
                        <Border Width="44" Height="44" CornerRadius="12" Background="#1AA78BFA" HorizontalAlignment="Left" Margin="0,0,0,12">
                            <Path Width="22" Height="22" Stretch="Uniform" Fill="{StaticResource Accent2Brush}"
                                  Data="M12,2 A10,10 0 1 0 12,22 A10,10 0 1 0 12,2 M12,6 v6 l4,2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="多主题 + 毛玻璃" FontWeight="SemiBold" FontSize="15" Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="支持淡蓝、紫色、深色等多套主题，配合毛玻璃效果，界面更现代" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- 剪贴板监控 -->
                <Border Style="{StaticResource CardBorder}" Padding="22" Margin="8,8,0,0">
                    <StackPanel>
                        <Border Width="44" Height="44" CornerRadius="12" Background="#1AFF9F2E" HorizontalAlignment="Left" Margin="0,0,0,12">
                            <Path Width="22" Height="22" Stretch="Uniform" Fill="{StaticResource WarningBrush}"
                                  Data="M19,2 h-4.18 a3,3 0 0 0 -2.83,-2 H12 a3,3 0 0 0 -2.83,2 H5 a2,2 0 0 0 -2,2 v16 a2,2 0 0 0 2,2 h14 a2,2 0 0 0 2,-2 V4 a2,2 0 0 0 -2,-2 z M12,7 a2,2 0 1 1 0,4 a2,2 0 0 1 0,-4 z M17,17 H7 v-1 c0,-1.5 3,-2.5 5,-2.5 s5,1 5,2.5 z" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="剪贴板监控" FontWeight="SemiBold" FontSize="15" Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="自动检测剪贴板中的下载链接，一键开始下载" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- 浏览器扩展横幅 -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="24" Margin="0,8,0,16" Background="{StaticResource BrandGradientBrush}" BorderBrush="Transparent">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="像 IDM 一样接管浏览器下载" Foreground="White" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="安装浏览器扩展后，网页中的任何下载链接都会自动交给 TDM 接管。"
                                   Foreground="#CCFFFFFF" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="扫描浏览器" Click="OnScanBrowsersClick" Margin="16,0,0,0"
                            Padding="22,10" FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                            Background="White" Foreground="{StaticResource PrimaryBrush}"
                            BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- 开始使用 -->
            <Border Grid.Row="3" Style="{StaticResource CardBorder}" Padding="22" Margin="0,8,0,0">
                <StackPanel>
                    <TextBlock Text="快速开始" Style="{StaticResource GroupTitle}" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource SurfaceAltBrush}" CornerRadius="10" Padding="14,12" Margin="0,0,4,0">
                            <StackPanel>
                                <Ellipse Width="22" Height="22" Fill="{StaticResource PrimaryBrush}" Margin="0,0,0,8">
                                    <Ellipse.OpacityMask>
                                        <VisualBrush Stretch="Uniform" Visual="{x:Null}"/>
                                    </Ellipse.OpacityMask>
                                </Ellipse>
                                <TextBlock Text="1. 安装扩展" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="扫描并安装 Chrome / Edge / Tabbit 等浏览器扩展" FontSize="11"
                                           Foreground="{StaticResource SubTextBrush}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="{StaticResource SurfaceAltBrush}" CornerRadius="10" Padding="14,12" Margin="4,0,0,0">
                            <StackPanel>
                                <TextBlock Text="2. 粘贴链接" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="把下载链接粘贴到下载任务页面，按回车即可开始" FontSize="11"
                                           Foreground="{StaticResource SubTextBrush}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>